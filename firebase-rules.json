{
  "rules": {
    "users": {
      "$uid": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },
    "teams": {
      ".read": "auth != null",
      "$teamId": {
        ".write": "auth != null && (!data.exists() || data.child('createdBy').val() === auth.uid)",
        ".validate": "newData.hasChildren(['teamId', 'name', 'createdBy', 'createdAt'])",
        "name": {
          ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 80"
        },
        "description": { ".validate": "newData.isString()" },
        "image": { ".validate": "newData.isString()" },
        "createdBy": { ".validate": "newData.isString()" },
        "teamId": { ".validate": "newData.isString()" },
        "createdAt": { ".validate": "newData.isNumber()" }
      }
    },
    "teamMembers": {
      ".read": "auth != null",
      "$teamId": {
        "$uid": {
          ".write": "auth != null && (auth.uid === $uid || root.child('teams').child($teamId).child('createdBy').val() === auth.uid)",
          ".validate": "!newData.exists() || newData.hasChildren(['uid', 'joinedAt'])"
        }
      }
    },
    "events": {
      ".read": "auth != null",
      "$eventId": {
        ".write": "auth != null && (!data.exists() || data.child('createdBy').val() === auth.uid)",
        ".validate": "newData.hasChildren(['eventId', 'title', 'date', 'createdBy', 'createdAt'])",
        "title": {
          ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 120"
        },
        "description": { ".validate": "newData.isString()" },
        "date": { ".validate": "newData.isString()" },
        "time": { ".validate": "newData.isString()" },
        "location": { ".validate": "newData.isString()" },
        "maxParticipants": {
          ".validate": "newData.isNumber() && newData.val() >= 0"
        },
        "teamId": { ".validate": "newData.isString()" },
        "eventId": { ".validate": "newData.isString()" },
        "createdBy": { ".validate": "newData.isString()" },
        "createdAt": { ".validate": "newData.isNumber()" }
      }
    },
    "eventParticipants": {
      ".read": "auth != null",
      "$eventId": {
        "$uid": {
          ".write": "auth != null && (auth.uid === $uid || root.child('events').child($eventId).child('createdBy').val() === auth.uid)",
          ".validate": "!newData.exists() || newData.hasChildren(['uid', 'joinedAt'])"
        }
      }
    }
  }
}
